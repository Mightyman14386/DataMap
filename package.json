{
    "name": "datamap",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "check": "biome check .",
        "check:unsafe": "biome check --write --unsafe .",
        "check:write": "biome check --write .",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "dev": "next dev --turbo",
        "preview": "next build && next start",
        "seed:risk-demo": "node --env-file=.env scripts/seed-risk-demo.mjs",
        "seed:policies": "node --env-file=.env scripts/seed-policy-cache.mjs",
        "start": "next start",
        "test:api": "powershell -NoProfile -ExecutionPolicy Bypass -File ./test-firebase-migration.ps1",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@auth/drizzle-adapter": "^1.7.2",
        "@t3-oss/env-nextjs": "^0.12.0",
        "@types/three": "^0.183.1",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.41.0",
        "firebase": "^12.10.0",
        "firebase-admin": "^13.7.0",
        "lucide-react": "^0.575.0",
        "next": "^15.2.3",
        "next-auth": "5.0.0-beta.25",
        "ogl": "^1.0.11",
        "postgres": "^3.4.4",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "three": "^0.183.2",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.5",
        "@types/node": "^20.14.10",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "drizzle-kit": "^0.30.5",
        "typescript": "^5.8.2"
    },
    "ct3aMetadata": {
        "initVersion": "7.40.0"
    },
    "packageManager": "npm@11.6.2"
}
